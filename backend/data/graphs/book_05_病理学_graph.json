    },
    {
      "id": "book_05_病理学_node_043",
      "name": "细胞不可逆性损伤",
      "definition": "细胞遭受严重损伤后，无法恢复，最终导致细胞死亡的病理过程。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 13,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_044",
      "name": "坏死",
      "definition": "细胞受到严重损伤后，细胞膜完整性破坏，细胞内容物释放，引发周围组织炎症反应的被动性细胞死亡形式。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 19,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_045",
      "name": "凋亡",
      "definition": "由基因调控的、主动的、程序性的细胞死亡过程，细胞膜保持完整，不引发炎症反应。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 21,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_046",
      "name": "坏死性凋亡",
      "definition": "一种受调控的细胞死亡形式，兼具坏死和凋亡的特征，依赖受体相互作用蛋白激酶（RIPK）介导。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 23,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_047",
      "name": "细胞焦亡",
      "definition": "一种依赖炎症小体激活、caspase-1介导的促炎性细胞死亡形式，常伴随细胞肿胀和膜破裂。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 23,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_048",
      "name": "铁死亡",
      "definition": "一种依赖铁离子和脂质过氧化驱动的非凋亡性细胞死亡形式，具有独特的形态和生化特征。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 24,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_049",
      "name": "自噬",
      "definition": "细胞通过溶酶体降解自身受损细胞器或蛋白质，以维持稳态的过程，过度自噬可导致细胞死亡。",
      "category": "生理机制",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 24,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_050",
      "name": "细胞膜完整性破坏",
      "definition": "坏死的关键特征，导致细胞内容物泄漏，引发炎症反应。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 19,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_051",
      "name": "炎症反应",
      "definition": "机体对坏死细胞释放内容物产生的防御性反应，表现为红、肿、热、痛。",
      "category": "临床表现",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 19,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_052",
      "name": "程序性细胞死亡",
      "definition": "由基因调控的、有序的细胞死亡过程，包括凋亡、坏死性凋亡、细胞焦亡等。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 13,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_053",
      "name": "炎症小体",
      "definition": "胞内多蛋白复合物，可激活caspase-1，介导细胞焦亡和促炎因子释放。",
      "category": "生理机制",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 23,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_054",
      "name": "脂质过氧化",
      "definition": "铁死亡的核心生化过程，导致细胞膜损伤和细胞死亡。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 24,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_055",
      "name": "溶酶体降解",
      "definition": "自噬过程中，溶酶体与自噬体融合，降解包裹的细胞内容物。",
      "category": "生理机制",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 24,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_056",
      "name": "细胞周期",
      "definition": "细胞从一次分裂结束到下一次分裂结束所经历的有序过程，包括间期和分裂期。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_057",
      "name": "不同类型细胞的再生潜能",
      "definition": "根据细胞周期状态和增殖能力，将细胞分为不稳定细胞、稳定细胞和永久性细胞三类，其再生潜能依次降低。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_058",
      "name": "不稳定细胞",
      "definition": "持续分裂的细胞，再生能力强，如表皮细胞、造血细胞、黏膜上皮细胞等。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_059",
      "name": "稳定细胞",
      "definition": "处于静止期（G0期）但可被刺激进入细胞周期的细胞，再生能力中等，如肝细胞、肾小管上皮细胞等。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_060",
      "name": "永久性细胞",
      "definition": "已退出细胞周期、不再分裂的细胞，再生能力极弱或无，如神经元、心肌细胞、骨骼肌细胞。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_061",
      "name": "干细胞",
      "definition": "具有自我更新和多向分化潜能的未分化细胞，是组织再生的基础。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_062",
      "name": "干细胞在再生中的作用",
      "definition": "干细胞通过增殖、分化和迁移，补充受损或死亡的细胞，参与组织修复和再生。",
      "category": "生理机制",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_063",
      "name": "组织再生的机制",
      "definition": "组织损伤后，通过细胞增殖、分化、迁移以及细胞外基质重塑等过程，恢复组织结构和功能。",
      "category": "生理机制",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_064",
      "name": "组织再生的过程",
      "definition": "包括炎症反应、细胞增殖、血管生成、基质沉积和重塑等连续步骤。",
      "category": "生理机制",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_065",
      "name": "细胞再生的影响因素",
      "definition": "影响细胞再生能力的各种因素，包括生长因子、细胞外基质、微环境、营养状态等。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_066",
      "name": "生长因子",
      "definition": "一类能刺激细胞增殖和分化的多肽类信号分子，如EGF、FGF、PDGF等。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_067",
      "name": "细胞外基质",
      "definition": "由胶原、蛋白聚糖、糖蛋白等组成的细胞外环境，对细胞增殖、迁移和分化起调控作用。",
      "category": "解剖结构",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_068",
      "name": "微环境",
      "definition": "细胞周围的局部环境，包括细胞外基质、邻近细胞、可溶性因子等，影响干细胞行为和再生过程。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    }
