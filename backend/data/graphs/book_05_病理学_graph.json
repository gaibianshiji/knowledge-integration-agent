{
  "textbook_id": "book_05_病理学",
  "textbook_name": "病理学",
  "nodes": [
    {
      "id": "book_05_病理学_node_001",
      "name": "适应",
      "definition": "细胞、组织或器官在环境变化或损伤刺激下，通过改变自身代谢、功能和结构以维持生存的过程。",
      "category": "核心概念",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_002",
      "name": "萎缩",
      "definition": "已发育正常的细胞、组织或器官体积缩小，常伴细胞数量减少，是适应性反应之一。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_003",
      "name": "肥大",
      "definition": "细胞、组织或器官体积增大，由细胞体积增大（实质细胞肥大）所致，可伴功能增强。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_004",
      "name": "增生",
      "definition": "组织或器官内实质细胞数量增多，常导致组织体积增大，是细胞增殖活跃的适应性反应。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_005",
      "name": "化生",
      "definition": "一种已分化成熟的组织类型被另一种分化成熟的组织类型取代的过程，属于适应性改变。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_006",
      "name": "细胞老化",
      "definition": "细胞随年龄增长或受内外因素影响，出现功能衰退、增殖能力下降、代谢紊乱等不可逆改变的过程。",
      "category": "生理机制",
      "chapter": "第一节　适应",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_007",
      "name": "生理性萎缩",
      "definition": "正常生理过程中发生的萎缩，如青春期后胸腺萎缩、老年性器官萎缩。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_008",
      "name": "病理性萎缩",
      "definition": "疾病或异常刺激导致的萎缩，如营养不良性萎缩、压迫性萎缩、失用性萎缩。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_009",
      "name": "代偿性肥大",
      "definition": "因功能需求增加或部分组织丧失，剩余细胞通过体积增大代偿功能，如高血压时心肌肥大。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_010",
      "name": "内分泌性肥大",
      "definition": "激素刺激引起的细胞体积增大，如妊娠期子宫平滑肌肥大。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_011",
      "name": "再生性增生",
      "definition": "组织损伤后通过细胞增殖修复缺损，如肝细胞再生、皮肤创伤愈合。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_012",
      "name": "激素性增生",
      "definition": "激素水平异常导致靶器官细胞数量增多，如雌激素过多引起子宫内膜增生。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_013",
      "name": "鳞状上皮化生",
      "definition": "柱状上皮或移行上皮被鳞状上皮取代，常见于慢性支气管炎时支气管黏膜上皮化生。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_014",
      "name": "肠上皮化生",
      "definition": "胃黏膜上皮被肠型上皮取代，常见于慢性胃炎，与胃癌发生相关。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_015",
      "name": "细胞老化机制",
      "definition": "包括端粒缩短、DNA损伤积累、氧化应激、蛋白质稳态失衡等，导致细胞功能衰退。",
      "category": "生理机制",
      "chapter": "第一节　适应",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_016",
      "name": "细胞和组织损伤的原因",
      "definition": "导致细胞和组织发生损伤的各种因素，包括缺氧、物理因素、化学因素、生物因素、免疫反应、遗传因素、营养失衡、衰老等。",
      "category": "核心概念",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_017",
      "name": "细胞和组织损伤的机制",
      "definition": "细胞损伤发生的具体分子和细胞生物学过程，包括ATP耗竭、氧自由基损伤、细胞内钙超载、膜损伤、蛋白质错误折叠等。",
      "category": "核心概念",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_018",
      "name": "缺氧",
      "definition": "组织氧供应不足或氧利用障碍，是导致细胞损伤最常见的原因之一，包括低氧性缺氧、贫血性缺氧、循环性缺氧和组织中毒性缺氧。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_019",
      "name": "物理因素",
      "definition": "引起细胞损伤的物理性刺激，如机械力、温度（高温烧伤、低温冻伤）、辐射、电击等。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_020",
      "name": "化学因素",
      "definition": "各种化学物质（如毒物、药物、环境污染物质）对细胞造成的直接或间接损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_021",
      "name": "生物因素",
      "definition": "病毒、细菌、真菌、寄生虫等病原体感染引起的细胞损伤，可通过直接破坏或间接免疫反应导致损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_022",
      "name": "免疫反应",
      "definition": "机体免疫系统异常反应（如自身免疫、过敏反应）导致的细胞和组织损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_023",
      "name": "遗传因素",
      "definition": "基因突变或染色体异常导致的细胞结构和功能缺陷，引起遗传性疾病相关的细胞损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_024",
      "name": "营养失衡",
      "definition": "营养物质的缺乏或过量（如蛋白质-能量营养不良、维生素缺乏、肥胖）导致的细胞代谢紊乱和损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_025",
      "name": "衰老",
      "definition": "随年龄增长，细胞逐渐丧失增殖和修复能力，对损伤的易感性增加，导致退行性变化。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_026",
      "name": "ATP耗竭",
      "definition": "细胞能量代谢障碍导致ATP水平下降，影响钠钾泵、蛋白质合成等关键生命活动，是损伤的核心机制之一。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_027",
      "name": "氧自由基损伤",
      "definition": "活性氧（ROS）等自由基产生过多或清除不足，导致脂质过氧化、蛋白质氧化和DNA损伤。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_028",
      "name": "细胞内钙超载",
      "definition": "细胞内钙离子浓度异常升高，激活多种酶（如磷脂酶、蛋白酶、核酸内切酶），破坏细胞结构。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_029",
      "name": "膜损伤",
      "definition": "细胞膜或细胞器膜（如线粒体膜、溶酶体膜）的完整性破坏，导致离子失衡、酶泄漏和细胞死亡。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_030",
      "name": "蛋白质错误折叠",
      "definition": "应激条件下蛋白质折叠异常，形成错误构象，引发内质网应激和未折叠蛋白反应，导致细胞损伤。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_031",
      "name": "细胞可逆性损伤",
      "definition": "细胞受到轻度、持续或短暂刺激后，出现的可恢复的形态和功能改变，是细胞损伤的早期阶段。",
      "category": "核心概念",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 14,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_032",
      "name": "细胞水肿",
      "definition": "细胞损伤最早出现的改变，因线粒体受损、ATP减少，导致钠水潴留，细胞体积增大，胞浆疏松淡染。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 15,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_033",
      "name": "脂肪变",
      "definition": "非脂肪细胞内出现中性脂肪（甘油三酯）异常蓄积，常见于肝、心、肾等器官，与脂代谢障碍有关。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 15,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_034",
      "name": "玻璃样变",
      "definition": "细胞内或间质中出现均质、嗜伊红半透明蛋白质蓄积，又称透明变性，常见于结缔组织、血管壁等。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 16,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_035",
      "name": "淀粉样变",
      "definition": "细胞外间质中出现淀粉样蛋白质-多糖复合物沉积，具有刚果红染色阳性、偏振光下呈苹果绿色双折射的特征。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 16,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_036",
      "name": "黏液样变",
      "definition": "间质内出现黏多糖（透明质酸等）和蛋白质的异常积聚，常见于间叶组织肿瘤、风湿病等。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_037",
      "name": "病理性色素沉着",
      "definition": "细胞内或间质中有异常色素（如含铁血黄素、胆红素、黑色素等）沉积，可由内源性或外源性色素引起。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_038",
      "name": "病理性钙化",
      "definition": "除骨和牙齿外，软组织内出现固态钙盐沉积，分为营养不良性钙化和转移性钙化两种类型。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_039",
      "name": "营养不良性钙化",
      "definition": "继发于局部坏死、变性或血栓等组织损伤的钙盐沉积，血钙正常，常见于结核坏死灶、动脉粥样硬化斑块。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_040",
      "name": "转移性钙化",
      "definition": "因全身性钙磷代谢障碍（如甲状旁腺功能亢进）导致血钙升高，钙盐沉积于正常组织，常见于肾、肺、胃黏膜。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_041",
      "name": "含铁血黄素沉着",
      "definition": "红细胞破坏后，血红蛋白分解产生的含铁色素（含铁血黄素）在局部或全身沉积，常见于陈旧性出血和溶血性疾病。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_05_病理学",
      "textbook_name": "病理学"
    },
    {
      "id": "book_05_病理学_node_042",
      "name": "胆红素沉着",
      "definition": "胆红素代谢障碍导致其在细胞内或间质中沉积，引起黄疸，常见于肝细胞损伤或胆道梗阻。",
      "category": "病理变化",
      "chapter": "第三节 细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_05_病理学",
