      "name": "微生物遗传学",
      "definition": "研究微生物遗传物质的结构、功能、变异和遗传规律的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_042",
      "name": "微生物基因组学",
      "definition": "研究微生物基因组的结构、功能、进化和比较基因组学的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_043",
      "name": "细菌学",
      "definition": "以细菌为研究对象，研究其形态、结构、生理、遗传及致病性的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_044",
      "name": "食品微生物学",
      "definition": "研究食品中微生物的种类、活动规律及其对食品安全和加工影响的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_045",
      "name": "农业微生物学",
      "definition": "研究农业环境中微生物与作物、土壤及动物相互关系的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_046",
      "name": "工业微生物学",
      "definition": "研究微生物在工业发酵、生物转化及产品开发中应用的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_047",
      "name": "病原微生物的生物学特性",
      "definition": "病原微生物的形态、结构、代谢、抗原性及抵抗力等固有特征。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_048",
      "name": "致病机制",
      "definition": "病原微生物引起宿主感染和疾病的分子与细胞机制，包括侵袭力、毒素等。",
      "category": "病理变化",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_049",
      "name": "抗感染免疫机制",
      "definition": "人体免疫系统识别、清除病原微生物并维持免疫记忆的防御机制。",
      "category": "生理机制",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_050",
      "name": "感染性疾病的病原学诊断",
      "definition": "通过微生物培养、抗原抗体检测、分子生物学等方法确定感染病原体的过程。",
      "category": "治疗方法",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_051",
      "name": "防治措施",
      "definition": "针对病原微生物感染所采取的预防（如疫苗）和治疗（如抗生素）手段。",
      "category": "治疗方法",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_052",
      "name": "微生物群与人体健康",
      "definition": "人体共生微生物群落的组成变化对健康状态和疾病发生的重要影响。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_053",
      "name": "基础医学",
      "definition": "研究人体正常结构和功能、疾病发生机制及药物作用原理的医学基础学科群。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_054",
      "name": "医学微生物学发展三个时期",
      "definition": "医学微生物学的发展过程大致分为三个时期：古代时期（17世纪中期以前）、实验微生物学时期（17世纪中期-20世纪中期）、现代微生物学时期（20世纪中期-现在）。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 22,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_055",
      "name": "古代微生物学知识",
      "definition": "古代人类虽未观察到具体微生物，但已利用微生物知识进行传染病防治，如人痘接种、煮沸消毒、隔离等。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 22,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_056",
      "name": "人痘接种法",
      "definition": "我国先民在明隆庆年间（1567-1572）开创的预防天花的方法，通过接种天花康复者的物质获得免疫力，后传至欧洲。",
      "category": "治疗方法",
      "chapter": "医学微生物学发展简史",
      "page": 22,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_057",
      "name": "列文虎克发现微生物",
      "definition": "1676年，荷兰人列文虎克利用自制显微镜首次观察到微生物，为微生物的存在提供了科学依据。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 22,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_058",
      "name": "巴斯德与微生物生理学",
      "definition": "法国科学家巴斯德通过曲颈瓶实验证明发酵和腐败由微生物引起，推翻了自然发生说，开创了微生物生理学时代，并创立了巴氏消毒法。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 23,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_059",
      "name": "郭霍法则",
      "definition": "德国学者郭霍于1884年提出的确定病原微生物的准则：1) 在患者中查见，健康人无；2) 能分离纯培养；3) 接种易感动物产生同样病症；4) 能从实验动物中重新分离。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 23,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_060",
      "name": "病毒的发现",
      "definition": "1892年伊凡诺夫斯基发现烟草花叶病由滤过性因子引起，后贝杰林克明确该因子需在活细胞中增殖，命名为病毒，开启了病毒学时代。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 23,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_061",
      "name": "免疫学的兴起",
      "definition": "18世纪末琴纳创用牛痘预防天花，后巴斯德研制出多种疫苗，贝林格使用白喉抗毒素进行被动免疫治疗，免疫学逐渐形成独立学科。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 24,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_062",
      "name": "吞噬细胞学说与体液抗体学说",
      "definition": "19世纪末两种免疫学观点：梅契尼可夫主张吞噬细胞学说，艾利希主张体液抗体学说，两者为免疫学发展奠定了基础。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 24,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_063",
      "name": "克隆选择学说",
      "definition": "1958年伯内特提出的抗体生成学说，阐明了抗体产生机制、抗原识别、自身耐受和自身免疫等免疫生物学现象。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 24,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_064",
      "name": "化学治疗剂和抗生素的发现",
      "definition": "艾利希合成砷凡纳明（606）开创化学治疗时代；弗莱明发现青霉素，弗洛里和钱恩提纯青霉素；瓦克斯曼发现链霉素，为结核病治疗提供药物。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 24,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_065",
      "name": "现代微生物学时期",
      "definition": "20世纪中期至今，分子生物学、基因组学等新技术推动微生物学迅速发展，新病原体不断发现，微生物诊断、疫苗研发取得突破。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 24,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_066",
      "name": "新现与再现病原体",
      "definition": "自1973年以来发现的近40种新病原体，如幽门螺杆菌、SARS冠状病毒、SARS冠状病毒2型等，以及再现病原体对人类健康构成严重威胁。",
      "category": "病理变化",
      "chapter": "医学微生物学发展简史",
      "page": 25,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_067",
      "name": "微生物基因组学",
      "definition": "1995年流感嗜血杆菌全基因组测序完成，开启了微生物基因组时代，结合蛋白质组学、代谢组学形成微生物系统生物学。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 25,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_068",
      "name": "病原微生物诊断技术",
      "definition": "从传统表型鉴定发展到基因型方法，如16S rDNA序列分析、PCR、全基因组测序、宏基因组测序等，提高了诊断的标准化和规范化水平。",
      "category": "治疗方法",
      "chapter": "医学微生物学发展简史",
      "page": 25,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_069",
      "name": "疫苗研发进展",
      "definition": "疫苗类型从灭活疫苗发展到减毒活疫苗、亚单位疫苗、工程疫苗、核酸疫苗等，SARS-CoV-2 mRNA疫苗是疫苗研发的最新突破。",
      "category": "治疗方法",
      "chapter": "医学微生物学发展简史",
      "page": 25,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_070",
      "name": "中国学者贡献",
      "definition": "汤飞凡分离沙眼衣原体，谢少文建立立克次体分离培养技术，朱既明裂解流感病毒为亚单位，我国在疫苗研制和计划免疫方面取得巨大成就。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 25,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_071",
      "name": "全健康理念",
      "definition": "强调将人类健康、动物健康和环境健康交叉融合，结合系统科学和人工智能，以应对新发传染病和微生物耐药性等挑战。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 25,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_072",
      "name": "细菌（广义）",
      "definition": "生物种系分类中细菌界成员，包括狭义细菌、立克次体、螺旋体等原核细胞型微生物。",
      "category": "核心概念",
      "chapter": "第一篇",
      "page": 26,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_073",
      "name": "细菌（狭义）",
      "definition": "原核细胞型微生物中数量最大、具有肽聚糖细胞壁的细菌，不包括立克次体和螺旋体。",
      "category": "核心概念",
      "chapter": "第一篇",
      "page": 26,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_074",
      "name": "原核细胞型微生物",
      "definition": "核分化程度低、无核膜和核仁、除核糖体外无其他细胞器的微生物。",
      "category": "核心概念",
      "chapter": "第一篇",
      "page": 26,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_075",
      "name": "细菌的遗传物质",
      "definition": "DNA，为细菌的遗传物质，位于原始核质中。",
      "category": "生理机制",
      "chapter": "第一篇",
      "page": 26,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_076",
      "name": "肽聚糖",
      "definition": "大多数细菌细胞壁中的特有成分，是细菌分类的重要标志。",
      "category": "解剖结构",
      "chapter": "第一篇",
      "page": 26,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_077",
      "name": "核糖体",
      "definition": "细菌细胞内唯一的细胞器，参与蛋白质合成。",
      "category": "解剖结构",
      "chapter": "第一篇",
      "page": 26,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_078",
      "name": "假单胞菌门",
      "definition": "与人类密切相关的九个细菌门之一，属于广义细菌。",
      "category": "核心概念",
      "chapter": "第一篇",
