{
  "textbook_id": "book_04_医学微生物学",
  "textbook_name": "医学微生物学",
  "nodes": [
    {
      "id": "book_04_医学微生物学_node_001",
      "name": "微生态失调",
      "definition": "正常微生物群之间、微生物与宿主之间、微生物与外界环境之间的平衡被破坏，导致宿主生理功能紊乱的病理状态。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_002",
      "name": "微生态失调的防治原则",
      "definition": "针对微生态失调的病因和机制，采取恢复和维持微生态平衡的一系列措施和策略。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_003",
      "name": "微生态平衡",
      "definition": "正常微生物群与宿主和环境之间保持动态平衡的生理状态，是健康的基础。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_004",
      "name": "正常微生物群",
      "definition": "寄居在人体体表和腔道中的、对宿主无害甚至有益的微生物群落，是微生态平衡的核心组成部分。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_005",
      "name": "益生菌",
      "definition": "通过改善宿主肠道微生态平衡而发挥有益作用的活性微生物制剂，常用于防治微生态失调。",
      "category": "治疗方法",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_006",
      "name": "益生元",
      "definition": "不被宿主消化吸收但能选择性促进肠道有益菌生长繁殖的物质，如低聚果糖。",
      "category": "治疗方法",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_007",
      "name": "抗生素相关性腹泻",
      "definition": "因使用抗生素导致肠道菌群失调而引发的腹泻，是微生态失调的常见临床表现。",
      "category": "临床表现",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_008",
      "name": "菌群失调",
      "definition": "正常微生物群的种类、数量和比例发生异常改变，是微生态失调的核心病理变化。",
      "category": "病理变化",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_009",
      "name": "抗生素滥用",
      "definition": "不合理或过度使用抗生素，是导致菌群失调和微生态失调的最常见医源性原因。",
      "category": "病理变化",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_010",
      "name": "粪菌移植",
      "definition": "将健康供体的粪便菌群移植到患者肠道内，以重建正常肠道微生态的治疗方法。",
      "category": "治疗方法",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_011",
      "name": "微生态调节剂",
      "definition": "包括益生菌、益生元、合生元等，用于调节微生态平衡、防治微生态失调的生物制剂。",
      "category": "治疗方法",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_012",
      "name": "宿主免疫力低下",
      "definition": "宿主免疫功能减弱，是导致微生态失调的重要内源性因素，易诱发条件致病菌感染。",
      "category": "病理变化",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_013",
      "name": "条件致病菌",
      "definition": "在正常微生态平衡时不致病，但在菌群失调或宿主免疫力低下时引起感染的微生物。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_014",
      "name": "微生态失调的预防",
      "definition": "通过合理使用抗生素、增强宿主免疫力、维持正常菌群等措施，防止微生态失调的发生。",
      "category": "治疗方法",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_015",
      "name": "合生元",
      "definition": "益生菌与益生元的复合制剂，兼具两者的优点，能更有效地调节微生态平衡。",
      "category": "治疗方法",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_016",
      "name": "微生物",
      "definition": "广泛存在于自然界中，肉眼直接观察不到，须借助光学显微镜或电子显微镜放大数百倍甚至数万倍才能观察到的微小生物。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_017",
      "name": "真核细胞型微生物",
      "definition": "最大的一类微生物，有典型的细胞结构，细胞器完整，细胞核分化程度高，有核膜和核仁，DNA为遗传物质。真菌属于此类。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_018",
      "name": "原核细胞型微生物",
      "definition": "有细胞基本结构，仅有核糖体；细胞核分化程度低，为原始核质，呈裸露DNA团块结构，无核膜和核仁，DNA为遗传物质。包括古菌和细菌。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_019",
      "name": "非细胞型微生物",
      "definition": "最小的一类微生物，无细胞结构，也无产生能量的酶系统，只能寄生在活细胞内生长增殖，只有一种类型的遗传物质（DNA或RNA）。病毒属于此类。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_020",
      "name": "古菌",
      "definition": "原核细胞型微生物的一类，不能合成肽聚糖且具有独特的代谢方式，可在高盐或低温等极端环境下生存，在人体内也有分布，但尚未发现对人类的致病性。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_021",
      "name": "细菌",
      "definition": "原核细胞型微生物的一类，具有细胞壁，与人体的健康密切相关，少数对人有致病性。部分细菌生物学性状比较特殊，如衣原体和立克次体等。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_022",
      "name": "病毒",
      "definition": "属于非细胞型微生物，是最小的一类微生物，无细胞结构，只能寄生在活细胞内生长增殖，遗传物质为DNA或RNA。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_023",
      "name": "微生物群",
      "definition": "定居在地球表面特定空间或生境的不同种类和数量的微生物。例如土壤微生物群数量最为庞大。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_024",
      "name": "微生物的分布特点",
      "definition": "微生物种类繁多、在自然界广泛分布，江河、空气、土壤、人体体表及腔道中都有大量微生物存在。",
      "category": "生理机制",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_025",
      "name": "微生物的繁殖与变异特点",
      "definition": "微生物具有繁殖迅速、容易变异等特点，如大肠埃希菌理论上24小时后可产生大量后代。",
      "category": "生理机制",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_026",
      "name": "微生物与生态环境平衡",
      "definition": "微生物参与生物圈碳、氮等物质的循环，维持生态环境的平衡。例如土壤微生物将有机氮转化为无机氮，固氮菌固定空气中的氮。",
      "category": "生理机制",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_027",
      "name": "微生物在农业中的应用",
      "definition": "微生物在农业中用于生产微生物饲料、肥料、农药、食品、能源和环保制剂等，如利用微生物分解有机物进行沤粪积肥。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_028",
      "name": "微生物在工业中的应用",
      "definition": "微生物在食品、采矿和新能源等领域应用广泛，如发酵生产抗生素、多元醇，冶金中用微生物浸矿提炼金属，石油工业中用于勘探和污染处理。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_029",
      "name": "微生物在环境保护中的应用",
      "definition": "微生物能够处理污水废气，降解有毒物质（如汞），通过新陈代谢中和废水中的碱，将有毒物质转化为无毒物质。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_030",
      "name": "微生物与人类健康的关系",
      "definition": "正常情况下，寄生在人体内的微生物无害，可帮助宿主消化吸收、合成营养物质、调节免疫代谢，并拮抗病原微生物入侵。",
      "category": "生理机制",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_031",
      "name": "微生物在生命科学中的应用",
      "definition": "微生物常被用作研究对象或模式生物，在基因、翻译、基因调控等规律发现中起关键作用，为基因工程提供工具酶和载体系统。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_032",
      "name": "病原微生物",
      "definition": "少数具有致病性，能引起人类、动物和植物感染性疾病的微生物。如志贺菌、结核分枝杆菌、脊髓灰质炎病毒等。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_033",
      "name": "机会致病性微生物",
      "definition": "正常情况下寄生在人体内不致病，但在特定情况下（如侵入其他部位）会导致人类疾病的微生物。例如大肠埃希菌侵入泌尿道或腹腔会引起感染。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_034",
      "name": "真菌",
      "definition": "属于真核细胞型微生物，具有典型的细胞结构和完整的细胞器，细胞核分化程度高。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_035",
      "name": "微生物的致病性",
      "definition": "少数微生物具有致病性，能引起人类、动物和植物感染性疾病，如人类痢疾、脊髓灰质炎、鸡霍乱、水稻白叶枯病等。",
      "category": "病理变化",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_036",
      "name": "微生物学",
      "definition": "研究微生物的种类、分布、遗传变异及其与人类、动植物和自然界相互关系的科学，是生命科学的重要领域。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_037",
      "name": "医学微生物学",
      "definition": "研究与医学相关的病原微生物的生物学特性、致病机制、人体抗感染免疫机制，以及感染性疾病的诊断和防治措施的学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_038",
      "name": "微生物分类学",
      "definition": "研究微生物分类、命名和系统发育关系的分支学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_04_医学微生物学",
      "textbook_name": "医学微生物学"
    },
    {
      "id": "book_04_医学微生物学_node_039",
      "name": "微生物生理学",
      "definition": "研究微生物的代谢、生长、繁殖等生命活动规律的分支学科。",
