{
  "textbook_id": "book_06_传染病学",
  "textbook_name": "传染病学",
  "nodes": [
    {
      "id": "book_06_传染病学_node_001",
      "name": "感染",
      "definition": "病原体与人体之间相互作用、相互斗争的过程，是传染病学的基本概念。",
      "category": "核心概念",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_002",
      "name": "感染过程的表现",
      "definition": "病原体侵入人体后，根据病原体与宿主相互作用的结果，呈现的不同临床表现形式。",
      "category": "核心概念",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_003",
      "name": "病原体",
      "definition": "能引起宿主疾病的微生物或寄生虫，是感染过程的启动因素。",
      "category": "核心概念",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_004",
      "name": "免疫应答",
      "definition": "机体免疫系统识别和清除病原体等抗原性异物的过程，包括非特异性免疫和特异性免疫。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_005",
      "name": "隐性感染",
      "definition": "感染过程中，病原体侵入人体后，仅引起机体产生特异性免疫应答，不出现或仅出现不明显的临床症状。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_006",
      "name": "显性感染",
      "definition": "感染过程中，病原体侵入人体后，不仅引起免疫应答，还导致组织损伤和病理改变，出现明显的临床症状。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_007",
      "name": "病原携带状态",
      "definition": "感染过程中，病原体在人体内持续存在并排出体外，但宿主不出现临床症状。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_008",
      "name": "潜伏性感染",
      "definition": "感染过程中，病原体潜伏在体内某些部位，当机体免疫力下降时，病原体被激活而致病。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_009",
      "name": "病原体的致病作用",
      "definition": "病原体通过其毒力、侵袭力、数量及变异性等因素，对宿主造成损害的能力。",
      "category": "病理变化",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_010",
      "name": "毒力",
      "definition": "病原体产生毒素（如内毒素、外毒素）的能力，是致病作用的重要因素。",
      "category": "核心概念",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_011",
      "name": "侵袭力",
      "definition": "病原体突破宿主防御屏障、在体内定植、繁殖和扩散的能力。",
      "category": "核心概念",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_012",
      "name": "非特异性免疫",
      "definition": "机体先天具有的、对多种病原体均有效的防御机制，包括屏障结构、吞噬细胞和体液因子等。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_013",
      "name": "特异性免疫",
      "definition": "机体在接触特定抗原后产生的、针对该抗原的专一性防御机制，包括细胞免疫和体液免疫。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_014",
      "name": "细胞免疫",
      "definition": "由T淋巴细胞介导的免疫应答，主要针对细胞内寄生的病原体。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_015",
      "name": "体液免疫",
      "definition": "由B淋巴细胞产生抗体介导的免疫应答，主要针对细胞外寄生的病原体。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_016",
      "name": "传染病的发生与发展",
      "definition": "描述病原体侵入人体后，在体内定位、繁殖、扩散以及引起宿主免疫反应和病理变化的整个过程。",
      "category": "核心概念",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_017",
      "name": "组织损伤的发生机制",
      "definition": "病原体或其产物（如毒素）直接或间接（通过免疫反应）导致宿主组织细胞结构和功能破坏的病理过程。",
      "category": "病理变化",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_018",
      "name": "重要的病理生理变化",
      "definition": "传染病过程中，机体在器官、系统水平出现的功能性或代谢性改变，如发热、炎症、休克等。",
      "category": "生理机制",
      "chapter": "传染病的发病机制",
      "page": 12,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_019",
      "name": "病原体入侵",
      "definition": "病原体（细菌、病毒等）通过特定途径（呼吸道、消化道等）进入宿主机体的初始步骤。",
      "category": "核心概念",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_020",
      "name": "病原体定位与繁殖",
      "definition": "病原体在宿主体内特定组织或细胞中定居并大量复制增殖的过程。",
      "category": "核心概念",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_021",
      "name": "病原体扩散",
      "definition": "病原体从原发部位通过血液、淋巴或直接蔓延等方式向全身或远处器官播散的过程。",
      "category": "核心概念",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_022",
      "name": "直接损伤",
      "definition": "病原体（如病毒在细胞内增殖）或其分泌的毒素直接破坏宿主细胞的结构和功能。",
      "category": "病理变化",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_023",
      "name": "免疫病理损伤",
      "definition": "宿主免疫系统在清除病原体过程中，过度或异常的免疫反应（如超敏反应、自身免疫）导致的组织损伤。",
      "category": "病理变化",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_024",
      "name": "炎症反应",
      "definition": "机体对病原体感染的一种防御性反应，表现为局部血管扩张、渗出和白细胞浸润，是重要的病理生理变化。",
      "category": "生理机制",
      "chapter": "传染病的发病机制",
      "page": 12,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_025",
      "name": "发热",
      "definition": "病原体或其产物（如内毒素）刺激机体产生致热原，导致体温调定点上移而引起的体温升高。",
      "category": "临床表现",
      "chapter": "传染病的发病机制",
      "page": 12,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_026",
      "name": "休克",
      "definition": "严重感染时，病原体毒素或炎症介质导致有效循环血量锐减、微循环障碍和组织灌注不足的危急病理生理状态。",
      "category": "病理变化",
      "chapter": "传染病的发病机制",
      "page": 12,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_027",
      "name": "毒素作用",
      "definition": "细菌等病原体释放的内毒素或外毒素，直接作用于靶细胞或诱导炎症介质释放，引起组织损伤和功能障碍。",
      "category": "病理变化",
      "chapter": "传染病的发病机制",
      "page": 13,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_028",
      "name": "传染病的流行过程",
      "definition": "传染病在人群中发生、传播和终止的过程，包括传染源、传播途径和易感人群三个基本环节。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_029",
      "name": "传染源",
      "definition": "体内有病原体生长、繁殖并能排出病原体的人和动物，包括患者、隐性感染者、病原携带者和受感染的动物。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_030",
      "name": "传播途径",
      "definition": "病原体从传染源排出后，侵入新易感宿主前，在外界环境中所经历的途径，如空气、水、食物、接触、虫媒等。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_031",
      "name": "易感人群",
      "definition": "对某种传染病缺乏特异性免疫力而容易感染的人群，其易感性受年龄、遗传、免疫状态等因素影响。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_032",
      "name": "流行过程的基本条件",
      "definition": "传染病流行必须具备的三个基本环节：传染源、传播途径和易感人群，三者缺一不可。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_033",
      "name": "患者作为传染源",
      "definition": "感染病原体后出现临床症状的个体，是重要的传染源，尤其在潜伏期和发病期排毒量高。",
      "category": "病理变化",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_034",
      "name": "隐性感染者",
      "definition": "感染病原体后无明显临床症状但能排出病原体的个体，常成为难以控制的传染源。",
      "category": "病理变化",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_035",
      "name": "病原携带者",
      "definition": "无临床症状但携带并排出病原体的个体，包括潜伏期携带者、恢复期携带者和健康携带者。",
      "category": "病理变化",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_036",
      "name": "空气传播",
      "definition": "通过飞沫、飞沫核或尘埃传播病原体的方式，常见于呼吸道传染病如流感、麻疹。",
      "category": "生理机制",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_037",
      "name": "水与食物传播",
      "definition": "通过被污染的水或食物传播病原体的方式，常见于肠道传染病如霍乱、伤寒。",
      "category": "生理机制",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_038",
      "name": "接触传播",
      "definition": "通过直接或间接接触传播病原体的方式，包括性传播、皮肤接触传播等。",
      "category": "生理机制",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_039",
      "name": "虫媒传播",
      "definition": "通过节肢动物（如蚊、蝇、蚤）叮咬或机械携带传播病原体的方式，如疟疾、登革热。",
      "category": "生理机制",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_040",
      "name": "影响流行过程的因素",
      "definition": "影响传染病流行过程发生和发展的各种因素，包括自然因素和社会因素。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 8,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_041",
      "name": "自然因素",
      "definition": "影响传染病流行的自然环境因素，如气候、地理、季节、温度、湿度等。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 8,
      "textbook_id": "book_06_传染病学",
      "textbook_name": "传染病学"
    },
    {
      "id": "book_06_传染病学_node_042",
      "name": "社会因素",
      "definition": "影响传染病流行的社会环境因素，如人口流动、卫生条件、医疗水平、生活习惯、经济状况等。",
