      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_004",
      "name": "实验病理学",
      "definition": "19世纪后期通过动物实验研究疾病机制的方法，是病理生理学的前身。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_005",
      "name": "临床病理生理学",
      "definition": "20世纪初期将病理生理学应用于临床，研究疾病发生发展规律的分支。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_006",
      "name": "分子病理生理学",
      "definition": "从分子水平研究疾病发生机制，是病理生理学未来趋势的重要方向。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_007",
      "name": "系统生物学",
      "definition": "整合基因组学、蛋白质组学等多组学数据，系统研究疾病网络的方法。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_008",
      "name": "精准医学",
      "definition": "基于个体基因、环境、生活方式差异，制定个性化疾病预防和治疗策略。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_009",
      "name": "桥梁学科",
      "definition": "病理生理学在基础医学（如生理学、病理学）与临床医学（如内科学）之间的连接作用。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_010",
      "name": "疾病机制研究",
      "definition": "病理生理学的核心任务，探索疾病发生、发展的功能与代谢变化规律。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_011",
      "name": "病理生理学",
      "definition": "研究疾病发生、发展过程中功能、代谢变化及其机制的学科，是连接基础医学与临床医学的桥梁学科。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_012",
      "name": "主要教学内容",
      "definition": "病理生理学课程的核心学习内容，包括疾病概论、基本病理过程和各系统病理生理学。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_013",
      "name": "疾病概论",
      "definition": "病理生理学教学内容的一部分，阐述疾病的概念、发生原因、发病条件及转归等一般规律。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_014",
      "name": "基本病理过程",
      "definition": "多种疾病中可能出现的共同的、成套的功能、代谢和结构变化，如发热、缺氧、休克等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_015",
      "name": "各系统病理生理学",
      "definition": "研究具体器官或系统在疾病状态下功能、代谢变化的规律和机制，如心血管、呼吸、消化系统等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_016",
      "name": "病理生理学研究手段概述",
      "definition": "用于研究疾病发生发展机制的各种实验方法和临床观察手段的简要介绍。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_017",
      "name": "动物实验",
      "definition": "病理生理学的重要研究手段，通过在动物身上复制人类疾病模型来研究发病机制。",
      "category": "治疗方法",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_018",
      "name": "临床观察",
      "definition": "在人体上进行的疾病研究手段，通过观察患者症状、体征及实验室检查结果来研究疾病规律。",
      "category": "治疗方法",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_019",
      "name": "细胞与分子生物学技术",
      "definition": "从细胞和分子水平研究疾病机制的技术手段，如基因敲除、蛋白质组学等。",
      "category": "治疗方法",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_020",
      "name": "学习方法",
      "definition": "学习病理生理学课程的有效策略和技巧，强调理解机制、联系临床和主动思考。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 17,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_021",
      "name": "理解机制",
      "definition": "学习方法之一，重点在于理解疾病发生发展的内在机制，而非死记硬背。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 17,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_022",
      "name": "联系临床",
      "definition": "学习方法之一，将病理生理学知识与临床疾病表现、诊断和治疗联系起来。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 17,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_023",
      "name": "主动思考",
      "definition": "学习方法之一，鼓励学生主动提问、分析和推理，培养临床思维能力。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 17,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_024",
      "name": "健康",
      "definition": "健康不仅是没有疾病或虚弱，而是身体、心理和社会适应方面的完好状态。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_025",
      "name": "疾病",
      "definition": "疾病是在一定病因作用下，机体自稳调节紊乱而发生的异常生命活动过程。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_026",
      "name": "亚健康",
      "definition": "亚健康是介于健康与疾病之间的一种生理功能低下的状态，又称第三状态或灰色状态。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_027",
      "name": "自稳调节紊乱",
      "definition": "机体在内外环境变化时，维持内环境相对稳定的调节机制出现障碍，导致疾病发生。",
      "category": "生理机制",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_028",
      "name": "病因",
      "definition": "引起疾病发生并赋予疾病特征的因素，包括生物性、物理性、化学性、营养性、遗传性、免疫性、心理社会性等。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_029",
      "name": "诱因",
      "definition": "能够加强病因作用或促进疾病发生的因素，本身不能引起疾病。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_030",
      "name": "疾病发生的一般规律",
      "definition": "疾病发生过程中普遍存在的规律，包括损伤与抗损伤、因果交替、局部与整体关系等。",
      "category": "病理变化",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_031",
      "name": "损伤与抗损伤反应",
      "definition": "疾病过程中，致病因素造成的损伤与机体抗损伤反应同时存在，贯穿疾病始终。",
      "category": "病理变化",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_032",
      "name": "因果交替",
      "definition": "疾病过程中，原始病因引起的结果可转化为新的病因，导致恶性循环或良性循环。",
      "category": "病理变化",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_033",
      "name": "局部与整体关系",
      "definition": "疾病过程中，局部病变可影响全身，全身状态也可影响局部病变的发展。",
      "category": "病理变化",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_034",
      "name": "疾病转归",
      "definition": "疾病发展的最终结局，包括完全康复、不完全康复和死亡。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_035",
      "name": "完全康复",
      "definition": "疾病过程中损伤完全修复，机体的功能、代谢和形态结构恢复正常，症状体征消失。",
      "category": "临床表现",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_036",
      "name": "不完全康复",
      "definition": "疾病后遗留某些病理变化或功能障碍，但机体通过代偿维持相对正常的生命活动。",
      "category": "临床表现",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_037",
      "name": "死亡",
      "definition": "机体生命活动和新陈代谢的永久终止，包括生理性死亡和病理性死亡。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_038",
      "name": "脑死亡",
      "definition": "全脑功能（包括大脑、小脑、脑干）不可逆性丧失，作为现代死亡判断标准。",
      "category": "核心概念",
      "chapter": "第一节 健康与疾病",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_039",
      "name": "病因学基础",
      "definition": "研究疾病发生原因和条件的科学，是病理生理学的重要基础。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_040",
      "name": "疾病发生的原因",
      "definition": "引起疾病并赋予疾病特征性的致病因素，是疾病发生的必要因素。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_041",
      "name": "疾病发生的条件",
      "definition": "影响疾病发生发展的各种环境、机体状态等因素，可促进或阻碍疾病发生。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_042",
      "name": "危险因素",
      "definition": "增加疾病发生可能性的各种因素，包括生物、环境、行为、遗传等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_043",
      "name": "致病因素",
      "definition": "直接导致疾病发生的具体因素，如物理、化学、生物因素等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_044",
      "name": "诱因",
      "definition": "能够促进或触发疾病发生的条件因素，如劳累、受凉、情绪波动等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_045",
      "name": "遗传因素",
      "definition": "通过基因突变或染色体异常导致疾病发生的生物因素。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
      "textbook_name": "病理生理学"
    },
    {
      "id": "book_07_病理生理学_node_046",
      "name": "环境因素",
      "definition": "包括自然环境和社会环境中的各种致病条件，如污染、气候、社会压力等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_07_病理生理学",
